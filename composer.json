{
  "name": "pltx/pterodactyl-theme",
  "description": "Modern Pterodactyl Panel theme and addon package",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0",
    "illuminate/routing": "^11.0",
    "illuminate/database": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Pltx\\Theme\\": "src/"
    }
  },
  "extra": {
